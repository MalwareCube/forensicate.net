---
import BaseLayout from '~/layouts/BaseLayout.astro';
import './styles.css';
---
<BaseLayout title="File Hex Viewer" description="Drop a file to view it as a classic offset, hex, and ASCII dump. Useful for inspecting binary files, identifying magic bytes, and verifying data at known offsets. Files are processed entirely in your browser, so nothing ever leaves your machine.">
  <h1>File Hex Viewer</h1>
  <p>
    Drop a file to view it as a classic <strong><a href="https://en.wikipedia.org/wiki/Hex_dump" target="_blank" rel="noopener noreferrer">hex dump</a></strong> showing offset, hex bytes, and ASCII side by side.
    Useful for inspecting binary files, identifying magic bytes at the start of a file,
    spotting embedded strings, and verifying data at known offsets.
  </p>
  <p class="post-meta">Files are processed entirely in your browser, so nothing ever leaves your machine.</p>

  <div class="decoder" id="hx">
    <div class="drop-zone" id="hx-drop">
      <p>Drop a file here, or use the file picker:</p>
      <input type="file" id="hx-file" />
    </div>

    <div id="hx-bar" class="hx-bar" style="display:none;">
      <div class="hx-meta">
        <span id="hx-name"></span>
        <span class="hx-dot">·</span>
        <span id="hx-size"></span>
        <span class="hx-dot">·</span>
        <span id="hx-range"></span>
        <button type="button" data-action="clear" class="hx-clear">Clear</button>
      </div>
      <div class="hx-controls">
        <div class="hx-ctrls-left">
          <span class="hx-ctrl-lbl">Go to</span>
          <input id="hx-goto" type="text" placeholder="0x0" spellcheck="false" />
        </div>
        <div class="hx-ctrls-right">
          <span class="hx-ctrl-lbl">Find</span>
          <input id="hx-find" type="text" placeholder="bytes or string" spellcheck="false" />
          <select id="hx-find-mode" aria-label="Search mode">
            <option value="ascii">ASCII</option>
            <option value="hex">Hex</option>
          </select>
          <span id="hx-find-status" class="hx-find-status"></span>
          <button type="button" id="hx-find-prev" aria-label="Previous match">←</button>
          <button type="button" id="hx-find-next" aria-label="Next match">→</button>
        </div>
      </div>
    </div>

    <p class="error" id="hx-error" role="status" aria-live="polite"></p>

    <div id="hx-output" class="hx-output-wrap" style="display:none;">
      <div id="hx-scroll" class="hx-scroll" tabindex="0">
        <div id="hx-inner" class="hx-inner">
          <div id="hx-rows" class="hx-rows"></div>
        </div>
      </div>
      <p class="hx-hint">Click and drag to select bytes, Esc to clear. PgUp/PgDn to page, Home/End for start/end, Enter in Find to step matches.</p>
    </div>
  </div>

  <h2>How it works</h2>
  <p>
    A hex dump presents a file's raw bytes in three aligned columns: the byte offset in
    hex, 16 bytes of hex per row (split into two groups of 8), and the ASCII representation
    of those bytes. Printable characters show as themselves; non-printable bytes appear as
    a dot.
  </p>


  <script is:inline>
    (function () {
      const root = document.getElementById('hx');
      if (!root) return;
      const drop = root.querySelector('#hx-drop');
      const fileInput = root.querySelector('#hx-file');
      const bar = root.querySelector('#hx-bar');
      const nameEl = root.querySelector('#hx-name');
      const sizeEl = root.querySelector('#hx-size');
      const rangeEl = root.querySelector('#hx-range');
      const gotoEl = root.querySelector('#hx-goto');
      const findEl = root.querySelector('#hx-find');
      const findMode = root.querySelector('#hx-find-mode');
      const findStatus = root.querySelector('#hx-find-status');
      const findPrev = root.querySelector('#hx-find-prev');
      const findNext = root.querySelector('#hx-find-next');
      const outputEl = root.querySelector('#hx-output');
      const scrollEl = root.querySelector('#hx-scroll');
      const innerEl = root.querySelector('#hx-inner');
      const rowsEl = root.querySelector('#hx-rows');
      const errEl = root.querySelector('#hx-error');
      const clearBtn = root.querySelector('[data-action="clear"]');

      const BYTES_PER_ROW = 16;
      const MAX_MATCHES = 1000;

      let currentFile = null;
      let totalRows = 0;
      let rowHeight = 18;
      let offsetWidth = 8;
      let renderedStart = -1;
      let renderedEnd = -1;
      let readToken = 0;
      let matches = [];
      let activeMatch = -1;
      let matchLen = 0;
      let searchToken = 0;
      let selStart = -1;
      let selEnd = -1;
      let isDragging = false;
      let hoverOff = -1;
      let visibleTop = 0;
      let visibleBot = 0;

      function setError(m) { errEl.textContent = m || ''; }
      function prettyBytes(n) {
        if (n < 1024) return n + ' B';
        if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KiB';
        if (n < 1024 * 1024 * 1024) return (n / 1024 / 1024).toFixed(2) + ' MiB';
        return (n / 1024 / 1024 / 1024).toFixed(2) + ' GiB';
      }
      function parseOffset(s) {
        s = (s || '').trim().replace(/[_,\s]/g, '');
        if (!s) return NaN;
        if (/^0x[0-9a-f]+$/i.test(s)) return parseInt(s.slice(2), 16);
        if (/^[0-9a-f]+$/i.test(s)) return parseInt(s, 16);
        return NaN;
      }
      function escapeHtml(s) {
        return s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));
      }
      function hexByte(b) { return b.toString(16).padStart(2, '0'); }
      function asciiByte(b) { return (b >= 0x20 && b <= 0x7e) ? String.fromCharCode(b) : '.'; }

      function rowHTML(rowOffset, bytes, rowMatches) {
        const off = rowOffset.toString(16).padStart(offsetWidth, '0');
        let hex = '';
        let asc = '';
        for (let j = 0; j < BYTES_PER_ROW; j++) {
          if (j === 8) hex += ' ';
          if (j < bytes.length) {
            const absOff = rowOffset + j;
            const b = bytes[j];
            const inMatch = rowMatches.some((m) => j >= m[0] && j < m[1]);
            const h = hexByte(b);
            const a = escapeHtml(asciiByte(b));
            const mCls = inMatch ? ' m' : '';
            hex += '<span class="hx-b' + mCls + '" data-off="' + absOff + '">' + h + '</span> ';
            asc += '<span class="hx-a' + mCls + '" data-off="' + absOff + '">' + a + '</span>';
          } else {
            hex += '   ';
            asc += ' ';
          }
        }
        return off + '  ' + hex + ' ' + asc;
      }

      function matchesOverlapping(byteStart, byteEnd) {
        const out = [];
        for (const m of matches) {
          const mEnd = m + matchLen;
          if (mEnd > byteStart && m < byteEnd) out.push([m, mEnd]);
        }
        return out;
      }

      async function scheduleRender() {
        if (!currentFile) return;
        const myToken = ++readToken;
        const scrollTop = scrollEl.scrollTop;
        const viewport = scrollEl.clientHeight;
        const firstVisible = Math.floor(scrollTop / rowHeight);
        const visibleCount = Math.ceil(viewport / rowHeight);
        const buffer = 10;
        const start = Math.max(0, firstVisible - buffer);
        const end = Math.min(totalRows, firstVisible + visibleCount + buffer);
        updateRangeLabel(firstVisible, visibleCount);
        if (start === renderedStart && end === renderedEnd) return;

        const byteStart = start * BYTES_PER_ROW;
        const byteEnd = Math.min(currentFile.size, end * BYTES_PER_ROW);
        const blob = currentFile.slice(byteStart, byteEnd);
        const bytes = new Uint8Array(await blob.arrayBuffer());
        if (myToken !== readToken) return;

        const overlap = matchesOverlapping(byteStart, byteEnd);
        const parts = [];
        for (let r = start; r < end; r++) {
          const rowOffset = r * BYTES_PER_ROW;
          const rowBytes = bytes.subarray((r - start) * BYTES_PER_ROW, (r - start + 1) * BYTES_PER_ROW);
          const localMatches = overlap
            .filter((m) => m[0] < rowOffset + BYTES_PER_ROW && m[1] > rowOffset)
            .map((m) => [Math.max(0, m[0] - rowOffset), Math.min(BYTES_PER_ROW, m[1] - rowOffset)]);
          parts.push('<div class="hx-row">' + rowHTML(rowOffset, rowBytes, localMatches) + '</div>');
        }
        rowsEl.innerHTML = parts.join('');
        rowsEl.style.transform = 'translateY(' + (start * rowHeight) + 'px)';
        renderedStart = start;
        renderedEnd = end;
        applyHighlight();
      }

      function updateRangeLabel(firstVisible, visibleCount) {
        if (!currentFile) return;
        visibleTop = firstVisible * BYTES_PER_ROW;
        visibleBot = Math.min(currentFile.size, (firstVisible + visibleCount) * BYTES_PER_ROW);
        renderStatus();
      }

      function renderStatus() {
        if (!currentFile) { rangeEl.textContent = ''; return; }
        if (selStart >= 0) {
          const lo = Math.min(selStart, selEnd);
          const hi = Math.max(selStart, selEnd);
          const len = hi - lo + 1;
          rangeEl.textContent = 'sel 0x' + lo.toString(16) + '–0x' + hi.toString(16) + ' (' + len + ' B)';
        } else if (hoverOff >= 0) {
          rangeEl.textContent = '0x' + hoverOff.toString(16);
        } else if (currentFile.size === 0) {
          rangeEl.textContent = '(empty)';
        } else {
          const lastByte = Math.max(0, visibleBot - 1);
          rangeEl.textContent = '0x' + visibleTop.toString(16) + '–0x' + lastByte.toString(16);
        }
      }

      function applyHighlight() {
        const spans = rowsEl.querySelectorAll('[data-off]');
        const hasSel = selStart >= 0;
        const lo = hasSel ? Math.min(selStart, selEnd) : -1;
        const hi = hasSel ? Math.max(selStart, selEnd) : -1;
        for (const el of spans) {
          const o = +el.dataset.off;
          el.classList.toggle('sel', hasSel && o >= lo && o <= hi);
          el.classList.toggle('hv', !isDragging && o === hoverOff);
        }
      }

      function clearSelection() {
        if (selStart < 0 && hoverOff < 0) return;
        selStart = -1;
        selEnd = -1;
        hoverOff = -1;
        applyHighlight();
        renderStatus();
      }

      function measureRowHeight() {
        rowsEl.innerHTML = '<div class="hx-row">&nbsp;</div>';
        const first = rowsEl.firstChild;
        const h = first.getBoundingClientRect().height;
        return h > 0 ? h : 18;
      }

      function setFile(f) {
        setError('');
        currentFile = f;
        totalRows = Math.max(1, Math.ceil(f.size / BYTES_PER_ROW));
        offsetWidth = Math.max(8, Math.max(0, f.size - 1).toString(16).length);
        bar.style.display = '';
        outputEl.style.display = '';
        nameEl.textContent = f.name;
        sizeEl.textContent = prettyBytes(f.size) + ' (' + f.size.toLocaleString() + ' bytes)';
        matches = [];
        activeMatch = -1;
        matchLen = 0;
        selStart = -1;
        selEnd = -1;
        hoverOff = -1;
        isDragging = false;
        updateFindStatus();
        renderedStart = -1;
        renderedEnd = -1;
        rowHeight = measureRowHeight();
        innerEl.style.height = (totalRows * rowHeight) + 'px';
        scrollEl.scrollTop = 0;
        scheduleRender();
      }

      function goToOffset(off) {
        if (!currentFile) return;
        if (!isFinite(off) || off < 0) return;
        const maxOff = Math.max(0, currentFile.size - 1);
        if (off > maxOff) off = maxOff;
        const row = Math.floor(off / BYTES_PER_ROW);
        scrollEl.scrollTop = row * rowHeight;
      }

      async function doSearch() {
        const myToken = ++searchToken;
        matches = [];
        activeMatch = -1;
        matchLen = 0;
        const raw = findEl.value;
        if (!raw || !currentFile) {
          updateFindStatus();
          renderedStart = -1;
          renderedEnd = -1;
          scheduleRender();
          return;
        }

        let pattern;
        if (findMode.value === 'hex') {
          const clean = raw.replace(/\s+/g, '');
          if (!clean) {
            updateFindStatus();
            renderedStart = -1;
            renderedEnd = -1;
            scheduleRender();
            return;
          }
          if (!/^[0-9a-f]+$/i.test(clean) || clean.length % 2 !== 0) {
            findStatus.textContent = 'invalid hex';
            renderedStart = -1;
            renderedEnd = -1;
            scheduleRender();
            return;
          }
          pattern = new Uint8Array(clean.length / 2);
          for (let i = 0; i < pattern.length; i++) pattern[i] = parseInt(clean.substr(i * 2, 2), 16);
        } else {
          pattern = new TextEncoder().encode(raw);
        }
        if (pattern.length === 0) {
          updateFindStatus();
          renderedStart = -1;
          renderedEnd = -1;
          scheduleRender();
          return;
        }

        matchLen = pattern.length;
        findStatus.textContent = 'searching…';

        const CHUNK = 1 << 20;
        let overlap = new Uint8Array(0);
        let overlapOff = 0;
        for (let off = 0; off < currentFile.size; off += CHUNK) {
          const end = Math.min(currentFile.size, off + CHUNK);
          const blob = currentFile.slice(off, end);
          const chunk = new Uint8Array(await blob.arrayBuffer());
          if (myToken !== searchToken) return;
          const combined = new Uint8Array(overlap.length + chunk.length);
          combined.set(overlap, 0);
          combined.set(chunk, overlap.length);
          const baseOff = overlapOff;
          const limit = combined.length - pattern.length;
          for (let i = 0; i <= limit; i++) {
            let ok = true;
            for (let j = 0; j < pattern.length; j++) {
              if (combined[i + j] !== pattern[j]) { ok = false; break; }
            }
            if (ok) {
              matches.push(baseOff + i);
              if (matches.length >= MAX_MATCHES) break;
            }
          }
          if (matches.length >= MAX_MATCHES) break;
          const overlapLen = Math.min(pattern.length - 1, combined.length);
          overlap = combined.slice(combined.length - overlapLen);
          overlapOff = baseOff + combined.length - overlapLen;
        }
        if (myToken !== searchToken) return;

        activeMatch = matches.length > 0 ? 0 : -1;
        updateFindStatus();
        if (activeMatch >= 0) goToOffset(matches[0]);
        renderedStart = -1;
        renderedEnd = -1;
        scheduleRender();
      }

      function updateFindStatus() {
        if (!findEl.value) { findStatus.textContent = ''; return; }
        if (matches.length === 0) { findStatus.textContent = 'no matches'; return; }
        const more = matches.length >= MAX_MATCHES ? '+' : '';
        findStatus.textContent = (activeMatch + 1) + ' of ' + matches.length + more;
      }

      function jumpMatch(delta) {
        if (matches.length === 0) return;
        activeMatch = (activeMatch + delta + matches.length) % matches.length;
        updateFindStatus();
        goToOffset(matches[activeMatch]);
      }

      fileInput.addEventListener('change', () => {
        const f = fileInput.files && fileInput.files[0];
        if (f) setFile(f);
      });
      drop.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('hover'); });
      drop.addEventListener('dragleave', () => drop.classList.remove('hover'));
      drop.addEventListener('drop', (e) => {
        e.preventDefault();
        drop.classList.remove('hover');
        const f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
        if (f) setFile(f);
      });

      let scrollScheduled = false;
      scrollEl.addEventListener('scroll', () => {
        if (scrollScheduled) return;
        scrollScheduled = true;
        requestAnimationFrame(() => {
          scrollScheduled = false;
          scheduleRender();
        });
      });

      gotoEl.addEventListener('change', () => {
        const raw = (gotoEl.value || '').trim();
        if (!raw) { setError(''); return; }
        const v = parseOffset(raw);
        if (!isFinite(v) || v < 0) { setError('Could not parse offset.'); return; }
        setError('');
        goToOffset(v);
      });
      gotoEl.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); gotoEl.dispatchEvent(new Event('change')); }
      });

      let findTimer = 0;
      findEl.addEventListener('input', () => {
        clearTimeout(findTimer);
        findTimer = setTimeout(doSearch, 250);
      });
      findMode.addEventListener('change', () => {
        clearTimeout(findTimer);
        findTimer = setTimeout(doSearch, 0);
      });
      findEl.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          if (matches.length > 0) jumpMatch(e.shiftKey ? -1 : 1);
        }
      });
      findPrev.addEventListener('click', () => jumpMatch(-1));
      findNext.addEventListener('click', () => jumpMatch(1));

      scrollEl.addEventListener('keydown', (e) => {
        if (e.key === 'PageDown') {
          e.preventDefault();
          scrollEl.scrollTop += scrollEl.clientHeight;
        } else if (e.key === 'PageUp') {
          e.preventDefault();
          scrollEl.scrollTop -= scrollEl.clientHeight;
        } else if (e.key === 'Home') {
          e.preventDefault();
          scrollEl.scrollTop = 0;
        } else if (e.key === 'End') {
          e.preventDefault();
          scrollEl.scrollTop = innerEl.offsetHeight;
        } else if (e.key === 'Escape') {
          clearSelection();
        }
      });

      rowsEl.addEventListener('mousedown', (e) => {
        const t = e.target.closest('[data-off]');
        if (!t) return;
        e.preventDefault();
        const off = +t.dataset.off;
        selStart = off;
        selEnd = off;
        isDragging = true;
        applyHighlight();
        renderStatus();
      });
      rowsEl.addEventListener('mousemove', (e) => {
        const t = e.target.closest('[data-off]');
        const off = t ? +t.dataset.off : -1;
        if (isDragging) {
          if (off >= 0 && off !== selEnd) {
            selEnd = off;
            applyHighlight();
            renderStatus();
          }
        } else if (off !== hoverOff) {
          hoverOff = off;
          applyHighlight();
          renderStatus();
        }
      });
      rowsEl.addEventListener('mouseleave', () => {
        if (!isDragging && hoverOff !== -1) {
          hoverOff = -1;
          applyHighlight();
          renderStatus();
        }
      });
      window.addEventListener('mouseup', () => {
        if (isDragging) {
          isDragging = false;
          applyHighlight();
        }
      });

      clearBtn.addEventListener('click', () => {
        readToken++;
        searchToken++;
        fileInput.value = '';
        currentFile = null;
        bar.style.display = 'none';
        outputEl.style.display = 'none';
        rowsEl.innerHTML = '';
        innerEl.style.height = '0';
        findEl.value = '';
        gotoEl.value = '';
        findStatus.textContent = '';
        matches = [];
        activeMatch = -1;
        matchLen = 0;
        selStart = -1;
        selEnd = -1;
        hoverOff = -1;
        isDragging = false;
        renderedStart = -1;
        renderedEnd = -1;
        setError('');
      });
    })();
  </script>
  <p class="post-meta tool-back"><a href="/tools/">&larr; All tools</a></p>
</BaseLayout>
