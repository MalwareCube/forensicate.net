---
import type { GetStaticPaths, Page } from 'astro';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostCard from '~/components/PostCard.astro';
import PostsSubNav from '~/components/PostsSubNav.astro';
import { getAllPosts, type Post } from '~/lib/posts';
import { site } from '~/site.config';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = await getAllPosts();
  return paginate(posts, { pageSize: site.postsPerPage });
};

interface Props { page: Page<Post>; }
const { page } = Astro.props;
---
<BaseLayout title={page.currentPage === 1 ? 'Posts' : `Posts | page ${page.currentPage}`}>
  <PostsSubNav />
  {page.data.map((p) => <PostCard post={p} />)}
  <div class="pagination">
    <span>
      {page.url.prev && <a href={page.url.prev}>← newer</a>}
    </span>
    <span class="page-info">page {page.currentPage} of {page.lastPage}</span>
    <span>
      {page.url.next && <a href={page.url.next}>older →</a>}
    </span>
  </div>
</BaseLayout>
