---
import type { GetStaticPaths, Page } from 'astro';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostCard from '~/components/PostCard.astro';
import PostsSubNav from '~/components/PostsSubNav.astro';
import { getAllPosts, postsByTag, type Post } from '~/lib/posts';
import { site } from '~/site.config';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = await getAllPosts();
  const byTag = postsByTag(posts);
  return Array.from(byTag.entries()).flatMap(([tag, tagPosts]) =>
    paginate(tagPosts, {
      params: { tag },
      pageSize: site.postsPerPage,
    }),
  );
};

interface Props { page: Page<Post>; }
const { page } = Astro.props;
const tag = Astro.params.tag as string;
---
<BaseLayout title={`Tag: ${tag}${page.currentPage === 1 ? '' : ` | page ${page.currentPage}`}`}>
  <PostsSubNav />
  <h1>Tag: <code>{tag}</code></h1>
  <p class="post-meta">{page.total} {page.total === 1 ? 'post' : 'posts'}</p>
  {page.data.map((p) => <PostCard post={p} />)}
  {page.lastPage > 1 && (
    <div class="pagination">
      <span>
        {page.url.prev && <a href={page.url.prev}>← newer</a>}
      </span>
      <span class="page-info">page {page.currentPage} of {page.lastPage}</span>
      <span>
        {page.url.next && <a href={page.url.next}>older →</a>}
      </span>
    </div>
  )}
</BaseLayout>
