---
import { site, socials } from '~/site.config';
---
<section class="widget about">
  <h3><a href="/about/">About</a></h3>
  <p>
    {site.author}. DFIR practitioner and threat hunter. Research, notes, and lessons learned live here.
    <a href="/about/">More →</a>
  </p>
  <div class="social">
    {socials.map((s) => <a href={s.href} target="_blank" rel="noopener noreferrer">{s.label}</a>)}
  </div>
</section>
