---
import type { MarkdownHeading } from 'astro';

interface Props { headings: MarkdownHeading[]; minCount?: number; }
const { headings, minCount = 3 } = Astro.props;

type TocItem = { slug: string; text: string; depth: number; children: TocItem[] };

const flat = headings
  .filter((h) => h.depth >= 2 && h.depth <= 4)
  .map((h) => ({ ...h, text: h.text.replace(/\s*#\s*$/, '') }));

const roots: TocItem[] = [];
let currentH2: TocItem | null = null;
let currentH3: TocItem | null = null;
for (const h of flat) {
  const node: TocItem = { slug: h.slug, text: h.text, depth: h.depth, children: [] };
  if (h.depth === 2) {
    roots.push(node);
    currentH2 = node;
    currentH3 = null;
  } else if (h.depth === 3) {
    if (currentH2) currentH2.children.push(node);
    else roots.push(node);
    currentH3 = node;
  } else {
    if (currentH3) currentH3.children.push(node);
    else if (currentH2) currentH2.children.push(node);
    else roots.push(node);
  }
}
const show = flat.length >= minCount;
---
{show && (
  <section class="widget side-toc" aria-label="Table of contents" data-side-toc>
    <h3>Table of Contents</h3>
    <ul class="side-toc-list">
      {roots.map((h) => (
        <li>
          <a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
          {h.children.length > 0 && (
            <ul class="side-toc-sublist">
              {h.children.map((c) => (
                <li>
                  <a href={`#${c.slug}`} data-toc-link={c.slug}>{c.text}</a>
                  {c.children.length > 0 && (
                    <ul class="side-toc-sublist">
                      {c.children.map((g) => (
                        <li>
                          <a href={`#${g.slug}`} data-toc-link={g.slug}>{g.text}</a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .side-toc {
    position: sticky;
    top: 1em;
    max-height: calc(100vh - 2em);
    overflow-y: auto;
  }

  .side-toc-list,
  .side-toc-sublist {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .side-toc-list > li {
    margin: 0;
    line-height: 1.35;
  }
  .side-toc-list > li > a {
    display: block;
    padding: 0.25em 0.5em 0.25em 0.6em;
    color: var(--text-muted);
    text-decoration: none;
    border-left: 3px solid transparent;
    margin-left: -0.6em;
    font-size: 0.95em;
  }
  .side-toc-list a:hover {
    color: var(--link-hover);
    text-decoration: underline;
  }

  .side-toc-sublist {
    padding: 0.1em 0 0.2em 0;
    margin: 0 0 0 0.5em;
    border-left: 1px dotted #bcbcbc;
  }
  .side-toc-sublist li {
    position: relative;
    margin: 0.1em 0;
    padding-left: 1em;
    line-height: 1.3;
  }
  .side-toc-sublist li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.75em;
    width: 0.55em;
    border-top: 1px dotted #bcbcbc;
  }
  .side-toc-sublist li a {
    display: block;
    padding: 0.15em 0.4em;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.88em;
    border-left: 3px solid transparent;
    margin-left: -0.4em;
    padding-left: 0.4em;
  }

  .side-toc-list a.is-active {
    color: #000;
    background: #fff3cd;
    border-left-color: #d95a1e;
  }

  @media (max-width: 820px) {
    .side-toc { display: none; }
  }
  body.theatre .side-toc { display: none; }
</style>

<script is:inline>
  (function () {
    function init() {
      const toc = document.querySelector('[data-side-toc]');
      if (!toc) return;

      const links = toc.querySelectorAll('a[data-toc-link]');
      if (links.length === 0) return;
      const entries = [];
      links.forEach((a) => {
        const el = document.getElementById(a.dataset.tocLink);
        if (el) entries.push({ link: a, el: el });
      });
      if (entries.length === 0) return;

      const setActive = (slug) => {
        links.forEach((a) => {
          a.classList.toggle('is-active', a.dataset.tocLink === slug);
        });
      };

      const update = () => {
        const vh = window.innerHeight;
        const scrollY = window.scrollY;
        const docHeight = document.documentElement.scrollHeight;

        // Near page bottom: force the last heading active so the final
        // section always reaches "current" on short pages.
        if (vh + scrollY >= docHeight - 4) {
          setActive(entries[entries.length - 1].link.dataset.tocLink);
          return;
        }

        // Reference line sits 30% down the viewport. The "active" heading
        // is the last one whose top has scrolled above this line. Picking
        // a line below the viewport top (instead of at it) gives close
        // headings some breathing room before the active item flips.
        const referenceY = vh * 0.3;
        let current = entries[0].link.dataset.tocLink;
        for (const { link, el } of entries) {
          if (el.getBoundingClientRect().top <= referenceY) {
            current = link.dataset.tocLink;
          } else {
            break;
          }
        }
        setActive(current);
      };

      // IntersectionObserver triggers updates when any heading crosses the
      // reference line. Scroll + resize are safety nets for states the
      // observer doesn't cover (page bottom, layout shifts).
      const observer = new IntersectionObserver(update, {
        rootMargin: '-30% 0px -70% 0px',
        threshold: 0,
      });
      entries.forEach(({ el }) => observer.observe(el));
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update, { passive: true });
      update();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
